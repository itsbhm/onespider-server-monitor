# Auto detect text files and perform line ending normalization
* text=auto eol=lf

# Explicitly declare text files you want to always be normalized
*.js text
*.html text
*.css text
*.md text
*.json text
*.sql text
*.yml text
*.yaml text

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary

# SVG is a text file, but vector images
*.svg text

# Exclude generated/vendor files from GitHub language statistics
node_modules/* linguist-vendored
package-lock.json linguist-generated
