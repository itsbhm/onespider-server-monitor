# ============================================
# OneSpider Monitor - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# Command: copy .env.example .env
# ============================================

# Target Server Information
# The details of the infrastructure you are monitoring
STATIC_IP=103.175.X.X
ISP_PROVIDER=NextGen Broadband Pvt Ltd
SERVER_ID=SRV-DEL-061
SERVER_LOCATION=Gurugram, Haryana, India 122001
MANAGED_BY=OneSpider NOC Team
ABUSE_EMAIL=abuse@onespider.net
HARDWARE_VENDOR=Dell Inc.

# Supabase Configuration
# Go to: Supabase Dashboard -> Project Settings -> API
# 1. Project URL goes here:
SUPABASE_URL=https://your-project-id.supabase.co
# 2. "service_role" (secret) key goes here (DO NOT use anon key here):
SUPABASE_KEY=your-service-role-key-here

# AWS SES Configuration  
# Get keys from: AWS Console -> IAM -> Users -> Access Keys
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=your-secret-access-key-here

# Alert Recipient
# Email address where you want to receive alerts
ADMIN_EMAIL=your-email@example.com
ADMIN_NAME=Your Name

# Sender Email
# Must be verified in your AWS SES account
SENDER_EMAIL=alerts@yourdomain.com
